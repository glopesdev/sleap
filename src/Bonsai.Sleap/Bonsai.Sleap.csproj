<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Title>Bonsai - SLEAP Library</Title>
    <Description>Bonsai Library for real-time multi-pose tracking using SLEAP with ONNX Runtime inference.</Description>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <TargetFrameworks>net472</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Bonsai.Core" Version="2.9.0" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime.Gpu" Version="1.24.3" />
    <PackageReference Include="OpenCV.Net" Version="3.4.1" />
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
  </ItemGroup>

</Project>